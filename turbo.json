{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "proto:gen": {
      "inputs": ["packages/proto/**/*.proto"],
      "outputs": ["packages/proto/generated/**"],
      "cache": true
    }
  }
}
