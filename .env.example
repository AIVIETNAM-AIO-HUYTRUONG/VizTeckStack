# =============================================================================
# ROOT .env.example — DOCUMENTATION ONLY, không được load file này trực tiếp.
# Mỗi app có file .env.example riêng, copy theo hướng dẫn từng section bên dưới.
# =============================================================================

# -----------------------------------------------------------------------------
# packages/db  →  copy thành  packages/db/.env
# apps/svc-roadmap  →  copy thành  apps/svc-roadmap/.env
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://vizteck:vizteck@localhost:5432/vizteckstack"

# -----------------------------------------------------------------------------
# apps/api-gateway  →  copy thành  apps/api-gateway/.env
# -----------------------------------------------------------------------------
ROADMAP_SERVICE_URL=localhost:5001
ADMIN_TOKEN=supersecret
PORT=3000

# -----------------------------------------------------------------------------
# apps/svc-roadmap  →  copy thành  apps/svc-roadmap/.env
# -----------------------------------------------------------------------------
GRPC_PORT=5001

# -----------------------------------------------------------------------------
# apps/web  →  copy thành  apps/web/.env.local
# apps/admin  →  copy thành  apps/admin/.env.local
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# apps/admin ONLY  →  thêm vào  apps/admin/.env.local
# Đăng nhập uploadthing.com → dashboard → tạo app → copy API token
# -----------------------------------------------------------------------------
UPLOADTHING_TOKEN=uploadthing_token_here
