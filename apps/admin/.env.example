NEXT_PUBLIC_API_URL=http://localhost:3000

# Clerk (sign in at clerk.com → create application → copy keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/roadmaps

# Uploadthing (sign in at uploadthing.com with Google free tier 2GB)
# Vào uploadthing.com → dashboard → tạo app (nếu chưa có) → copy API token
# Tạo file apps/admin/.env.local:
UPLOADTHING_TOKEN=uploadthing_token_here
